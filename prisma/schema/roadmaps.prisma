// ─── Roadmaps ────────────────────────────────────────────────
// Generated from an Analysis (its gap_skills feed the prompt) and
// owned by a User. Contains N weeks.
//
//   Analyses ──< Roadmaps ──< RoadmapWeeks ──< Resources
//                                      └──< DailyTasks

model Roadmaps {
  id             String        @id @default(uuid())
  analysis_id    String
  user_id        String
  duration_weeks Int
  status         RoadmapStatus @default(active)
  created_at     DateTime      @default(now())

  analysis Analyses       @relation(fields: [analysis_id], references: [id], onDelete: Cascade)
  user     Users          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  weeks    RoadmapWeeks[]

  @@index([analysis_id])
  @@index([user_id])
  @@index([status])
  @@map("roadmaps")
}
